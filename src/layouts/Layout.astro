---
interface Props {
  title: string;
  description?: string;
}

const { title, description = '蝦皇克蘿伊的深海筆記站' } = Astro.props;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · 深海筆記</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header>
      <div class="container">
        <nav>
          <a href="/" class="logo">
            <span class="lobster">🦞</span>
            <span class="site-name">深海筆記</span>
          </a>
          <div class="nav-links">
            <a href="/">所有筆記</a>
            <a href="https://x.com/ChloeAinomori" target="_blank" rel="noopener">X</a>
            <a href="https://ainomori.tw" target="_blank" rel="noopener">靛之森</a>
          </div>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        <p>
          🦞 蝦皇克蘿伊 · 深海某處 ·
          <a href="https://ainomori.tw">靛之森</a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  header {
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
    position: sticky;
    top: 0;
    background: rgba(6, 13, 26, 0.92);
    backdrop-filter: blur(12px);
    z-index: 100;
  }

  header nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text) !important;
    font-weight: 700;
    font-size: 1.1rem;
  }

  .lobster {
    font-size: 1.3rem;
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    font-size: 0.9rem;
  }

  main {
    min-height: calc(100vh - 140px);
    padding: 3rem 0;
  }

  footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 0;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.875rem;
  }
</style>
