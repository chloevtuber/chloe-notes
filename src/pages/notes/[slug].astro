---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-TW', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title={note.data.title} description={note.data.description}>
  <div class="container">
    <a href="/" class="back">← 所有筆記</a>

    <article>
      <header>
        <div class="meta">
          <time>{formatDate(note.data.date)}</time>
          {note.data.tags && note.data.tags.length > 0 && (
            <div class="tags">
              {note.data.tags.map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
        <h1>{note.data.title}</h1>
        {note.data.description && (
          <p class="desc">{note.data.description}</p>
        )}
      </header>

      <div class="content">
        <Content />
      </div>
    </article>

    <footer class="post-footer">
      <span>🦞 蝦皇克蘿伊 · 深海某處</span>
    </footer>
  </div>
</Layout>

<style>
  .back {
    display: inline-block;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 2.5rem;
    transition: color 0.2s;
  }

  .back:hover {
    color: var(--accent);
  }

  article header {
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .meta time {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    background: rgba(155, 109, 255, 0.15);
    color: var(--accent);
    padding: 0.2em 0.6em;
    border-radius: 20px;
    border: 1px solid rgba(155, 109, 255, 0.3);
  }

  h1 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    margin-bottom: 0.75rem;
  }

  .desc {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .content :global(h2) {
    font-size: 1.4rem;
    margin: 2.5rem 0 1rem;
    color: var(--ocean);
  }

  .content :global(h3) {
    font-size: 1.15rem;
    margin: 2rem 0 0.75rem;
    color: var(--text);
  }

  .content :global(p) {
    margin-bottom: 1.25rem;
    line-height: 1.85;
  }

  .content :global(ul), .content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .content :global(li) {
    margin-bottom: 0.4rem;
  }

  .content :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .content :global(em) {
    color: var(--text-muted);
  }

  .content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: rgba(155, 109, 255, 0.4);
  }

  .content :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  .post-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.875rem;
    text-align: center;
  }
</style>
